generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String    @default("")
  address      String    @default("")
  image        String    @default("")
  role         String    @default("student")
  isPaid       Boolean   @default(false)
  lastDevice   String    @default("")
  createdAt    DateTime  @default(now())
  attempts     Attempt[]
}

model Question {
  id            String   @id @default(cuid())
  topic         String
  chapter       String   @default("General")
  text          String   @db.Text
  options       Json
  correctIndex  Int
  solutionSteps String   @db.Text
  trick         String   @db.Text
  difficulty    String   @default("Easy")
  source        String   @default("seed")
  createdAt     DateTime @default(now())
  attempts      Attempt[]
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  chosenIndex Int
  isCorrect   Boolean
  answeredAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])
}

model Note {
  id         String   @id @default(cuid())
  title      String
  subject    String
  url        String   @db.Text
  uploadedBy String
  createdAt  DateTime @default(now())
}